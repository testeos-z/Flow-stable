# =============================================================================
# logs/ — Grafana Observability Stack
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env — it's already in .gitignore
# =============================================================================

# ---- Grafana ----
# Admin credentials for the Grafana web UI
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=yourpassword123
GF_DEFAULT_INSTANCE_NAME=Grafana

# Grafana plugins (currently only grafana-clock-panel)
# simple-json and piechart-panel removed — unsupported in Grafana 11.x
GF_INSTALL_PLUGINS=grafana-clock-panel

# ---- Loki ----
# Internal URL for Loki (used by Grafana datasource provisioning)
LOKI_INTERNAL_URL=http://loki:3100

# ---- Prometheus ----
# Internal URL for Prometheus (used by Grafana datasource provisioning)
PROMETHEUS_INTERNAL_URL=http://prometheus:9090

# ---- Tempo ----
# Internal URL for Tempo (used by Grafana datasource provisioning)
TEMPO_INTERNAL_URL=http://tempo:3200

# ---- Flowise Metrics API Key ----
# Required by Prometheus to scrape Flowise metrics with Bearer auth.
# Generate this in Flowise UI → API Keys. DO NOT hardcode the value in config files.
# In Railway: set as a secret and mount to /run/secrets/flowise_api_key
FLOWISE_METRICS_API_KEY=your-flowise-api-key-here
