PORT=4100
NODE_ENV=development

# Secreto para validar Bearer tokens (JWT)
JWT_SECRET=your_jwt_secret_here

# URL base de la API upstream (Railway)
TARGET_API_URL=https://api.example.com

# Orígenes permitidos por CORS (separados por coma). Si no se define, permite todos.
# CORS_ORIGIN=https://gobernai.com,https://staging.gobernai.com
