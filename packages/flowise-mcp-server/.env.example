# Use host.docker.internal to reach Flowise running on the host's port 3000
FLOWISE_BASE_URL=http://host.docker.internal:3000
FLOWISE_API_KEY=your-api-key-here

# Railway PostgreSQL (direct DB access for chatflow diagnosis & repair)
# Used by diagnose_chatflow and repair_chatflow tools to bypass API viewport stripping
FLOWISE_DB_HOST=
FLOWISE_DB_PORT=
FLOWISE_DB_NAME=railway
FLOWISE_DB_USER=postgres
FLOWISE_DB_PASSWORD=
FLOWISE_DB_SSL=false
