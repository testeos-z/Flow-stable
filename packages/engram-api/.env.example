# Variables de entorno para desarrollo local
# En Railway, configurar estas en el dashboard del servicio.

# --- Conexión a Engram Cloud ---
# Local: http://localhost:7437 (si corre engram serve local)
# Railway: URL pública o internal hostname del servicio engram-cloud
ENGRAM_URL=http://localhost:7437

# Token para Engram Cloud autenticado (opcional en local, requerido si engram-cloud tiene ENGRAM_CLOUD_TOKEN)
ENGRAM_API_TOKEN=

# --- Servicio REST API ---
PORT=7438
NODE_ENV=development
LOG_LEVEL=info

# CORS y Rate Limiting
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
