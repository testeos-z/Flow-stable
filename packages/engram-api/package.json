{
    "name": "@flowise/engram-api",
    "version": "1.0.0",
    "description": "Engram Cloud REST API Service for Flowise",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "clean": "rimraf dist",
        "nuke": "pnpm clean && rimraf node_modules .turbo",
