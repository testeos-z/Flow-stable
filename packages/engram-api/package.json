        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "axios": "1.12.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "express": "^4.17.3",
        "express-rate-limit": "^6.9.0",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "winston": "^3.9.0",
        "zod": "^3.25.76 || ^4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.13",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "nodemon": "^2.0.22",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.3.2",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=18.15.0 <19.0.0 || ^20"
