echo "  • 302 nodos catalogados"
echo "  • 5 reference documents"
echo "  • NEW: 05-node-flow-compatibility.md (¡aclara CHATFLOW vs AGENTFLOW!)"
echo ""

echo "Agent Creation Commands:"
